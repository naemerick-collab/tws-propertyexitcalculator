{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/calculator", "destination": "/property-exit-strategy-calculator-v2.html" },
    { "source": "/portal", "destination": "/property-exit-strategy-calculator-v2-portal.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow" }
      ]
    }
  ]
}
